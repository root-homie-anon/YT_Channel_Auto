# youtube-automation — environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ElevenLabs
ELEVENLABS_API_KEY=

# Flux (image generation)
FLUX_API_KEY=

# Gemini / Nano Banana 2 (thumbnail generation)
GEMINI_API_KEY=

# Sonauto (music generation)
SONAUTO_API_KEY=

# Runway (photo-to-video animation)
RUNWAY_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
