# === YT_Channel_Auto Environment Variables ===

# Flux (Image Generation)
FLUX_API_KEY=
FLUX_API_URL=

# ElevenLabs (Voice Over)
ELEVENLABS_API_KEY=

# Replicate (Stable Audio 2.5 — Music Generation)
REPLICATE_API_TOKEN=

# Runway ML (Animation)
RUNWAY_API_KEY=

# Telegram Bot (Approval Gate)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini / Nano Banana 2 (Thumbnail Generation)
GEMINI_API_KEY=

# Anthropic (Prompt Grounding — Claude Haiku)
ANTHROPIC_API_KEY=

# Tavily (Visual Reference Search for Prompt Grounding)
TAVILY_API_KEY=

# YouTube OAuth (for channel initialization)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ZapCap (Video Captions)
ZAPCAP_API_KEY=
ZAPCAP_API_SECRET=

# Supabase (Asset Archival)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_USER=
DASHBOARD_PASS=

# General
NODE_ENV=production
LOG_LEVEL=info
