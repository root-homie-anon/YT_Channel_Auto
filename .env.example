# === YT_Channel_Auto Environment Variables ===

# Flux (Image Generation)
FLUX_API_KEY=
FLUX_API_URL=

# ElevenLabs (Voice Over)
ELEVENLABS_API_KEY=

# Sonauto (Music Generation)
SONAUTO_API_KEY=

# Runway ML (Animation)
RUNWAY_API_KEY=

# YouTube Data API
YOUTUBE_API_KEY=

# Telegram Bot (Approval Gate)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini / Nano Banana 2 (Thumbnail Generation)
GEMINI_API_KEY=

# YouTube OAuth (for channel initialization)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_USER=
DASHBOARD_PASS=

# General
NODE_ENV=production
LOG_LEVEL=info
